{
    // ---- Nix language server (nixd) ----
    "nix.enableLanguageServer": true,
    "nix.serverPath": "nixd",
    "nix.serverSettings": {
        "nixd": {
            "formatting": {
                "command": ["nixfmt"]
            },
            // allowUnfree — иначе hover/дополнение по unfree-пакетам (jetbrains, vscode) падает с ошибкой eval
            "nixpkgs": {
                "expr": "import (builtins.getFlake (toString ./.)).inputs.nixpkgs { system = builtins.currentSystem; config.allowUnfree = true; }"
            },
            "options": {
                "nixos": {
                    "expr": "(builtins.getFlake (toString ./.)).nixosConfigurations.main.options"
                },
                // homeConfigurations.nixd импортирует весь home.nix, поэтому его
                // .options — уже полный набор home-опций (базовые + programs.plasma /
                // programs.nixcord из модулей-инпутов). getSubOptions [] не нужен. См. flake.nix.
                "home-manager": {
                    "expr": "(builtins.getFlake (toString ./.)).homeConfigurations.nixd.options"
                },
                "flake-schemas": {
                    "expr": "let flake = builtins.getFlake (toString ./.); in flake.outputs"
                }
            }
        }
    },

    // ---- Комфорт для .nix файлов ----
    "[nix]": {
        "editor.defaultFormatter": "jnoortheen.nix-ide",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.suggest.insertMode": "replace"
    },

    // ---- Навигация по исходникам флейк-инпутов (папка ./inputs, см. алиас nin) ----
    // Не следим за read-only симлинками в /nix/store — иначе watcher грузит CPU.
    "files.watcherExclude": {
        "**/inputs/**": true
    },
    // nixpkgs гигантский — исключаем из поиска, чтобы Ctrl+Shift+F не висел.
    // Остальные инпуты (home-manager, nix-jetbrains-plugins, …) остаются в поиске.
    "search.exclude": {
        "inputs/nixpkgs": true,
        "result": true
    },
    // Симлинки указывают в /nix/store — переходить по ним без подтверждений.
    "explorer.excludeGitIgnore": false
}